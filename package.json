{
  "name": "holdem-cli",
  "version": "1.0.0",
  "description": "Texas Holdem in CLI",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts --debug",
    "game": "node dist/index.js",
    "build": "tsc",
    "package": "pkg . --target node18-win-x64 --output texas-holdem.exe",
    "start": "node dist/index.js"
  },
  "keywords": [
    "poker",
    "texas-holdem",
    "cli",
    "game"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pkg": "^5.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "."
  }
}
